# Пример файла конфигурации для скриптов импорта AMDA
# Скопируйте этот файл в .env и заполните своими данными:
#   cp .env.example .env
# ВНИМАНИЕ: файл .env никогда не должен попасть в git!

# ─── ЕМИАС ──────────────────────────────────────────────────────────────────
# Логин — номер мобильного телефона или СНИЛС
EMIAS_USERNAME=+7XXXXXXXXXX

# Пароль от личного кабинета ЕСИА (Госуслуги)
EMIAS_PASSWORD=your_password_here

# ─── Инвитро ─────────────────────────────────────────────────────────────────
INVITRO_USERNAME=+7XXXXXXXXXX
INVITRO_PASSWORD=your_password_here

# ─── Хеликс ──────────────────────────────────────────────────────────────────
HELIX_USERNAME=+7XXXXXXXXXX
HELIX_PASSWORD=your_password_here

# ─── Гемотест ────────────────────────────────────────────────────────────────
GEMOTEST_USERNAME=+7XXXXXXXXXX
GEMOTEST_PASSWORD=your_password_here

# ─── Медси ───────────────────────────────────────────────────────────────────
MEDSI_USERNAME=+7XXXXXXXXXX
MEDSI_PASSWORD=your_password_here

# ─── Общие настройки ─────────────────────────────────────────────────────────
# Период выгрузки в днях (по умолчанию 180)
IMPORT_PERIOD_DAYS=180

# Запускать браузер в фоновом режиме (true/false)
HEADLESS=false

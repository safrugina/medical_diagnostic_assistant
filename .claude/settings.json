{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Edit",
      "Write",
      "Create",
      "Bash",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(tree *)"
    ],
    "defaultMode": "auto"
  }
}
